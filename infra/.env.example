# PostgreSQL
POSTGRES_USER=infoagua
POSTGRES_PASSWORD=senha
POSTGRES_DB=infoagua

# Backend
DATABASE_URL="postgresql://infoagua:senha@localhost:5432/infoagua?schema=public"

JWT_SECRET="change-me-your-secure-jwt-secret-key"
JWT_EXPIRES_IN=7d

PORT=3000

# Storage (MinIO)
MINIO_ROOT_USER=infoagua
MINIO_ROOT_PASSWORD=infoaguasecret
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=infoagua
STORAGE_SECRET_KEY=infoaguasecret
STORAGE_BUCKET=infoagua-uploads
STORAGE_REGION=us-east-1

# OpenWeather
OPENWEATHER_API_KEY=key
