{
  "expo": {
    "name": "InfoÁgua",
    "slug": "infoagua",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/infoagua-logo.png",
    "scheme": "infoagua",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/infoagua-logo.png"
    },
    "android": {
      "icon": "./assets/images/infoagua-logo.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/infoagua-logo.png",
        "monochromeImage": "./assets/images/infoagua-logo.png"
      },
      "predictiveBackGestureEnabled": true,
      "package": "br.edu.ifrn.infoagua"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/infoagua-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/infoagua-logo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}